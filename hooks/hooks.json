{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/secret_guard.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/docs_readonly_guard.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pii_check.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/verification_guard.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/spec_traceability_check.py\"" },
          { "type": "command", "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/post_format.py\"" }
        ]
      }
    ]
  }
}
